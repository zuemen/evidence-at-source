{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@eas/shared": ["packages/shared/src/index.ts"],
      "@eas/issuer": ["packages/issuer/src/index.ts"],
      "@eas/agents": ["packages/agents/src/index.ts"],
      "@eas/reconciliation": ["packages/reconciliation/src/index.ts"],
      "@eas/web": ["packages/web/src/demo/world.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/test/**/*.ts",
    "vitest.config.ts",
    "packages/web/vite.config.ts"
  ],
  "exclude": ["node_modules", "poc"]
}
